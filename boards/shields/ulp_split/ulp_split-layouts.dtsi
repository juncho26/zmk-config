// See https://zmk.dev/docs/development/hardware-integration/physical-layouts
// for how to configure this.

#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan>;

        // Edit this to define the positions and sizes of the keys, or remove it
        // if your keyboard will not support ZMK Studio.
        // https://zmk.dev/docs/development/hardware-integration/physical-layouts#optional-keys-property
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100  200    40     0     0     0>
            , <&key_physical_attrs 100 100  300    0      0     0     0>
            , <&key_physical_attrs 100 100  400    60     0     0     0>
            , <&key_physical_attrs 100 100  500    80     0     0     0>
            , <&key_physical_attrs 100 100  700    80     0     0     0>
            , <&key_physical_attrs 100 100  800    60     0     0     0>
            , <&key_physical_attrs 100 100  900    0      0     0     0>
            , <&key_physical_attrs 100 100  1000   40     0     0     0>
            , <&key_physical_attrs 100 100  0      140    0     0     0>
            , <&key_physical_attrs 100 100  100    120    0     0     0>
            , <&key_physical_attrs 100 100  200    140    0     0     0>
            , <&key_physical_attrs 100 100  300    100    0     0     0>
            , <&key_physical_attrs 100 100  400    160    0     0     0>
            , <&key_physical_attrs 100 100  500    180    0     0     0>
            , <&key_physical_attrs 100 100  700    180    0     0     0>
            , <&key_physical_attrs 100 100  800    160    0     0     0>
            , <&key_physical_attrs 100 100  900    100    0     0     0>
            , <&key_physical_attrs 100 100  1000   140    0     0     0>
            , <&key_physical_attrs 100 100  1100   120    0     0     0>
            , <&key_physical_attrs 100 100  1200   140    0     0     0>
            , <&key_physical_attrs 100 100  0      240    0     0     0>
            , <&key_physical_attrs 100 100  100    220    0     0     0>
            , <&key_physical_attrs 100 100  200    240    0     0     0>
            , <&key_physical_attrs 100 100  300    200    0     0     0>
            , <&key_physical_attrs 100 100  400    260    0     0     0>
            , <&key_physical_attrs 100 100  500    280    0     0     0>
            , <&key_physical_attrs 100 100  700    280    0     0     0>
            , <&key_physical_attrs 100 100  800    260    0     0     0>
            , <&key_physical_attrs 100 100  900    200    0     0     0>
            , <&key_physical_attrs 100 100  1000   240    0     0     0>
            , <&key_physical_attrs 100 100  1100   220    0     0     0>
            , <&key_physical_attrs 100 100  1200   240    0     0     0>
            , <&key_physical_attrs 100 100  0      340    0     0     0>
            , <&key_physical_attrs 100 100  100    320    0     0     0>
            , <&key_physical_attrs 100 100  200    340    0     0     0>
            , <&key_physical_attrs 100 100  300    300    0     0     0>
            , <&key_physical_attrs 100 100  400    360    0     0     0>
            , <&key_physical_attrs 100 100  500    380    0     0     0>
            , <&key_physical_attrs 100 100  700    380    0     0     0>
            , <&key_physical_attrs 100 100  800    360    0     0     0>
            , <&key_physical_attrs 100 100  900    300    0     0     0>
            , <&key_physical_attrs 100 100  1000   340    0     0     0>
            , <&key_physical_attrs 100 100  1100   320    0     0     0>
            , <&key_physical_attrs 100 100  1200   340    0     0     0>
            ;
    };
};
